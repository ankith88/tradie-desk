# AI
OPENAI_API_KEY=sk-...

# Email (get free API key at resend.com)
RESEND_API_KEY=re_...

# Airtable (get at airtable.com/create/apikey)
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# Business Details (used in quotes and invoices)
BUSINESS_NAME=Rapid Response Plumbing
BUSINESS_ABN=12 345 678 901
BUSINESS_EMAIL=steve@rapidresponseplumbing.com.au
BUSINESS_PHONE=0412 345 678
BUSINESS_ADDRESS=Sydney, NSW 2000
BUSINESS_BANK_DETAILS=BSB: 062-000 | Account: 12345678 | Bank: CBA

# Xero Integration (optional — get from developer.xero.com)
# Create a "Web App" and set redirect URI to: http://localhost:3001/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3001/api/xero/callback
# Webhook signing key — from Xero Developer Portal → Webhooks
XERO_WEBHOOK_KEY=

# Demo email (optional — routes demo emails to this address instead of the fake customer)
DEMO_EMAIL=

# Server
PORT=3001
NODE_ENV=development
